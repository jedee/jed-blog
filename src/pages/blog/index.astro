---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog — Jedi Ojeh</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav>
    <a href="/">← Home</a>
    <a href="https://jedi.zo.space">Portfolio</a>
  </nav>
  <main>
    <header>
      <p class="label">Writing</p>
      <h1>Ideas, Systems &<br/>Lessons Built in Public</h1>
      <p class="sub">Writing on engineering, Nigerian tech, and building things that actually work.</p>
    </header>
    <div class="grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="card">
          <div class="card-meta">{post.data.date}</div>
          <h2>{post.data.title}</h2>
          {post.data.description && <p>{post.data.description}</p>}
          <div class="tags">
            {post.data.tags?.map(t => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </main>
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Outfit', sans-serif; background: #0a0a0f; color: #e2e8f0; min-height: 100vh; }
  nav { display: flex; gap: 20px; padding: 24px 40px; border-bottom: 1px solid rgba(255,255,255,0.06); }
  nav a { color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; }
  nav a:hover { color: #818cf8; }
  main { max-width: 900px; margin: 0 auto; padding: 60px 24px 120px; }
  header { margin-bottom: 60px; }
  .label { color: #6366f1; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; }
  h1 { font-family: 'Playfair Display', serif; font-size: clamp(32px, 6vw, 56px); font-weight: 700; line-height: 1.15; color: #f8fafc; margin-bottom: 16px; }
  .sub { color: #64748b; font-size: 16px; max-width: 480px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
  .card { display: block; background: #111827; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 28px; text-decoration: none; transition: border-color 0.2s, transform 0.2s; }
  .card:hover { border-color: rgba(99,102,241,0.5); transform: translateY(-2px); }
  .card-meta { color: #475569; font-size: 12px; margin-bottom: 10px; }
  .card h2 { font-size: 17px; font-weight: 700; color: #f1f5f9; line-height: 1.35; margin-bottom: 10px; }
  .card p { color: #64748b; font-size: 13px; line-height: 1.6; margin-bottom: 14px; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { background: rgba(99,102,241,0.12); color: #818cf8; padding: 2px 8px; border-radius: 99px; font-size: 10px; font-weight: 600; }
</style>
